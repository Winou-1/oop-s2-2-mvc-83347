@model IEnumerable<FoodSafetyInspection.Domain.Inspection>
@using FoodSafetyInspection.Domain
@{
    ViewData["Title"] = "Inspections";
    string? currentSort = ViewBag.SortBy;
    bool monthOnly = ViewBag.MonthOnly == true;
    bool canEdit = User.IsInRole("Admin") || User.IsInRole("Inspector");
    bool isAdmin = User.IsInRole("Admin");
}

<h1>Inspections</h1>

@if (monthOnly)
{
    <div class="alert alert-info d-flex align-items-center justify-content-between">
        <span>Showing inspections for <strong>this month only</strong>.</span>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Show all</a>
    </div>
}

<form method="get" class="row g-2 mb-3">
    <input type="hidden" name="monthOnly" value="@monthOnly.ToString().ToLower()" />
    <div class="col-md-4">
        <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search premises or notes..." />
    </div>
    <div class="col-md-2">
        <select name="outcome" class="form-select">
            <option value="">All Outcomes</option>
            @foreach (InspectionOutcome o in Enum.GetValues(typeof(InspectionOutcome)))
            {
                <option value="@o" selected="@(o == (InspectionOutcome?)ViewBag.Outcome)">@o</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="sortBy" class="form-select">
            <option value="" selected="@(currentSort == null)">Sort: Date Newest</option>
            <option value="date_asc" selected="@(currentSort == "date_asc")">Sort: Date Oldest</option>
            <option value="score" selected="@(currentSort == "score")">Sort: Score High→Low</option>
            <option value="score_asc" selected="@(currentSort == "score_asc")">Sort: Score Low→High</option>
            <option value="premises" selected="@(currentSort == "premises")">Sort: Premises A–Z</option>
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-primary">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (canEdit)
{
    <p><a asp-action="Create" class="btn btn-success">+ New Inspection</a></p>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Premises</th>
            <th>Date</th>
            <th>Score</th>
            <th>Outcome</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Premises?.Name</td>
                <td>@item.InspectionDate.ToShortDateString()</td>
                <td>@item.Score</td>
                <td>
                    <span class="badge @(item.Outcome == InspectionOutcome.Pass ? "bg-success" : "bg-danger")">
                        @item.Outcome
                    </span>
                </td>
                <td class="d-flex gap-1">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    @if (isAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">No inspections found matching your criteria.</p>
}
