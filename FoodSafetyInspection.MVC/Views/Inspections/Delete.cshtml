@model FoodSafetyInspection.Domain.Inspection
@using FoodSafetyInspection.Domain
@{
    ViewData["Title"] = "Delete Inspection";
    int followUpCount = Model.FollowUps.Count;
    bool hasDependants = followUpCount > 0;
}

<h1 class="text-danger">Delete Inspection</h1>
<hr />

@if (hasDependants)
{
    <div class="alert alert-danger border border-danger-subtle shadow-sm mb-4">
        <h5 class="alert-heading fw-bold">This will permanently delete:</h5>
        <ul class="mb-0 mt-2">
            <li><strong>1</strong> inspection — <em>@Model.Premises?.Name, @Model.InspectionDate.ToShortDateString()</em></li>
            <li><strong>@followUpCount</strong> follow-up@(followUpCount != 1 ? "s" : "") linked to this inspection</li>
        </ul>
        <hr />
        <p class="mb-0 fw-semibold">This action <u>cannot be undone</u>. Are you absolutely sure?</p>
    </div>
}
else
{
    <div class="alert alert-warning mb-4">
        <p class="mb-0">
            Are you sure you want to delete this inspection for
            <strong>@Model.Premises?.Name</strong> on
            <strong>@Model.InspectionDate.ToShortDateString()</strong>?
            This cannot be undone.
        </p>
    </div>
}

<div class="card mb-4 shadow-sm" style="max-width: 480px;">
    <div class="card-header bg-secondary text-white fw-semibold">Inspection to be deleted</div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Premises</dt>
            <dd class="col-sm-8">@Model.Premises?.Name</dd>

            <dt class="col-sm-4">Date</dt>
            <dd class="col-sm-8">@Model.InspectionDate.ToShortDateString()</dd>

            <dt class="col-sm-4">Score</dt>
            <dd class="col-sm-8">@Model.Score / 100</dd>

            <dt class="col-sm-4">Outcome</dt>
            <dd class="col-sm-8">
                <span class="badge @(Model.Outcome == InspectionOutcome.Pass ? "bg-success" : "bg-danger")">
                    @Model.Outcome
                </span>
            </dd>

            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <dt class="col-sm-4">Notes</dt>
                <dd class="col-sm-8 text-muted"><em>@Model.Notes</em></dd>
            }

            @if (hasDependants)
            {
                <dt class="col-sm-4 mt-2">Follow-ups</dt>
                <dd class="col-sm-8 mt-2">@followUpCount</dd>
            }
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    @Html.AntiForgeryToken()

    <button type="submit" class="btn btn-danger me-2">
        @if (hasDependants)
        {
            <span>Yes, delete inspection + @followUpCount follow-up@(followUpCount != 1 ? "s" : "")</span>
        }
        else
        {
            <span>Delete</span>
        }
    </button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
