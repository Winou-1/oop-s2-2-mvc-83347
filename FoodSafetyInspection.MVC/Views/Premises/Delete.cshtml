@model FoodSafetyInspection.Domain.Premises
@using FoodSafetyInspection.Domain
@{
    ViewData["Title"] = "Delete Premises";
    int inspectionCount = Model.Inspections.Count;
    int followUpCount = Model.Inspections.Sum(i => i.FollowUps.Count);
    bool hasDependants = inspectionCount > 0;
}

<h1 class="text-danger">Delete Premises</h1>
<hr />

@* ── Danger banner when linked data exists ── *@
@if (hasDependants)
{
    <div class="alert alert-danger border border-danger-subtle shadow-sm mb-4">
        <h5 class="alert-heading fw-bold">This will permanently delete:</h5>
        <ul class="mb-0 mt-2">
            <li><strong>1</strong> premises — <em>@Model.Name</em></li>
            <li>
                <strong>@inspectionCount</strong> inspection@(inspectionCount != 1 ? "s" : "")
            </li>
            @if (followUpCount > 0)
            {
                <li>
                    <strong>@followUpCount</strong> follow-up@(followUpCount != 1 ? "s" : "")
                </li>
            }
        </ul>
        <hr />
        <p class="mb-0 fw-semibold">This action <u>cannot be undone</u>. Are you absolutely sure?</p>
    </div>
}
else
{
    <div class="alert alert-warning mb-4">
        <p class="mb-0">Are you sure you want to delete <strong>@Model.Name</strong>? This cannot be undone.</p>
    </div>
}

@* ── Premises summary card ── *@
<div class="card mb-4 shadow-sm" style="max-width: 480px;">
    <div class="card-header bg-secondary text-white fw-semibold">Premises to be deleted</div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Address</dt>
            <dd class="col-sm-8">@Model.Address</dd>

            <dt class="col-sm-4">Town</dt>
            <dd class="col-sm-8">@Model.Town</dd>

            <dt class="col-sm-4">Risk Rating</dt>
            <dd class="col-sm-8">
                <span class="badge @(Model.RiskRating == RiskRating.High ? "bg-danger" :
                                                                               Model.RiskRating == RiskRating.Medium ? "bg-warning text-dark" : "bg-success")">
                    @Model.RiskRating
                </span>
            </dd>

            @if (hasDependants)
            {
                <dt class="col-sm-4 mt-2">Inspections</dt>
                <dd class="col-sm-8 mt-2">@inspectionCount</dd>

                <dt class="col-sm-4">Follow-ups</dt>
                <dd class="col-sm-8">@followUpCount</dd>
            }
        </dl>
    </div>
</div>

@* ── Action buttons ── *@
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    @Html.AntiForgeryToken()

    <button type="submit" class="btn btn-danger me-2">
        @if (hasDependants)
        {
            <span>Yes, delete everything</span>
        }
        else
        {
            <span>Delete</span>
        }
    </button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
