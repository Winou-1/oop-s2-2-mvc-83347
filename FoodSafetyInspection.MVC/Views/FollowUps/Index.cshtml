@model IEnumerable<FoodSafetyInspection.Domain.FollowUp>
@using FoodSafetyInspection.Domain
@{
    ViewData["Title"] = "Follow-Ups";
    bool overdueOnly = ViewBag.OverdueOnly == true;
    bool canEdit = User.IsInRole("Admin") || User.IsInRole("Inspector");
}

<h1>Follow-Ups</h1>

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

@if (overdueOnly)
{
    <div class="alert alert-warning d-flex align-items-center justify-content-between">
        <span>Showing <strong>overdue follow-ups only</strong>.</span>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Show all</a>
    </div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">All Statuses</option>
            @foreach (FollowUpStatus s in Enum.GetValues(typeof(FollowUpStatus)))
            {
                <option value="@s" selected="@(s == (FollowUpStatus?)ViewBag.FilterStatus)">@s</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="sortBy" class="form-select">
            <option value="" selected="@(ViewBag.SortBy == null)">Sort: Status then Due Date</option>
            <option value="due_desc" selected="@(ViewBag.SortBy == "due_desc")">Sort: Due Date Desc</option>
            <option value="premises" selected="@(ViewBag.SortBy == "premises")">Sort: Premises A–Z</option>
            <option value="status" selected="@(ViewBag.SortBy == "status")">Sort: Status</option>
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-primary">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (canEdit)
{
    <p><a asp-action="Create" class="btn btn-success">+ New Follow-Up</a></p>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Premises</th>
            <th>Inspection Date</th>
            <th>Due Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var overdue = item.Status == FollowUpStatus.Open && item.DueDate < DateTime.Today;
            var daysLeft = (item.DueDate - DateTime.Today).Days;

            <tr class="@(overdue ? "table-danger" : "")">
                <td>@item.Inspection?.Premises?.Name</td>
                <td>@item.Inspection?.InspectionDate.ToShortDateString()</td>
                <td>
                    @item.DueDate.ToShortDateString()
                    @if (item.Status == FollowUpStatus.Open)
                    {
                        if (overdue)
                        {
                            <span class="text-danger small ms-1">(@(Math.Abs(daysLeft)) day(s) overdue)</span>
                        }
                        else
                        {

                            <span class="text-muted small ms-1">(@daysLeft day(s) left)</span>
                        }
                    }
                </td>
                <td>
                    <span class="badge @(item.Status == FollowUpStatus.Closed ? "bg-success" : overdue ? "bg-danger" : "bg-warning text-dark")">
                        @(overdue ? "OVERDUE" : item.Status.ToString())
                    </span>
                </td>
                <td class="d-flex gap-1">
                    @* Details button — visible to all roles *@
                    <a asp-action="Details" asp-route-id="@item.Id"
                       class="btn btn-sm btn-info">Details</a>
                    <a asp-controller="Premises" asp-action="Details"
                       asp-route-id="@item.Inspection?.Premises?.Id"
                       class="btn btn-sm btn-outline-secondary">Premises</a>

                    @* Close button — Inspector and Admin only *@
                    @if (canEdit && item.Status == FollowUpStatus.Open)
                    {
                        <form asp-action="Close" asp-route-id="@item.Id" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-success">Close</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">No follow-ups found matching your criteria.</p>
}
