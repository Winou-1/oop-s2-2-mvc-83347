@model FoodSafetyInspection.Domain.FollowUp
@using FoodSafetyInspection.Domain
@{
    ViewData["Title"] = "Follow-Up Details";
    bool canEdit = User.IsInRole("Admin") || User.IsInRole("Inspector");
    var isOverdue = Model.Status == FollowUpStatus.Open && Model.DueDate < DateTime.Today;
    var daysLeft = (Model.DueDate - DateTime.Today).Days;
    var daysAgo = Model.Inspection?.InspectionDate != null
                    ? (DateTime.Today - Model.Inspection.InspectionDate).Days : 0;
}

<h1>Follow-Up Details</h1>
<hr />

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

@* Status banner *@
@if (Model.Status == FollowUpStatus.Closed)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
        <strong>✔ Closed</strong> — closed on @Model.ClosedDate?.ToShortDateString()
    </div>
}
else if (isOverdue)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
        <strong>⚠ Overdue</strong> — @(Math.Abs(daysLeft)) day(s) past due date
    </div>
}
else
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4">
        <strong>⏳ Open</strong> — @daysLeft day(s) remaining
    </div>
}

<div class="row mb-4">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Premises</dt>
            <dd class="col-sm-8">
                <a asp-controller="Premises" asp-action="Details"
                       asp-route-id="@Model.Inspection?.PremisesId">
                    @Model.Inspection?.Premises?.Name
                </a>
                @if (Model.Inspection?.Premises?.RiskRating != null)
                {
                    var rr = Model.Inspection.Premises.RiskRating;
                    <span class="badge ms-1 @(rr == RiskRating.High ? "bg-danger" : rr == RiskRating.Medium ? "bg-warning text-dark" : "bg-success")">
                        @rr
                    </span>
                }
            </dd>

            <dt class="col-sm-4">Inspection</dt>
            <dd class="col-sm-8">
                <a asp-controller="Inspections" asp-action="Details"
                       asp-route-id="@Model.InspectionId">
                    @Model.Inspection?.InspectionDate.ToShortDateString()
                </a>
                <span class="text-muted small ms-1">(@daysAgo day(s) ago)</span>
                <span class="badge ms-1 @(Model.Inspection?.Outcome == InspectionOutcome.Pass ? "bg-success" : "bg-danger")">
                    @Model.Inspection?.Outcome
                </span>
            </dd>

            <dt class="col-sm-4">Due Date</dt>
            <dd class="col-sm-8">
                @Model.DueDate.ToShortDateString()
                @if (Model.Status == FollowUpStatus.Open)
                {
                    if (isOverdue)
                    {
                        <span class="badge bg-danger ms-1">@(Math.Abs(daysLeft)) day(s) overdue</span>
                    }
                    else
                    {

                        <span class="badge bg-warning text-dark ms-1">@daysLeft day(s) left</span>
                    }
                }
            </dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                <span class="badge fs-6 @(Model.Status == FollowUpStatus.Closed ? "bg-success" : isOverdue ? "bg-danger" : "bg-warning text-dark")">
                    @(isOverdue ? "OVERDUE" : Model.Status.ToString())
                </span>
            </dd>

            @if (Model.ClosedDate.HasValue)
            {
                <dt class="col-sm-4">Closed On</dt>
                <dd class="col-sm-8">@Model.ClosedDate.Value.ToShortDateString()</dd>
            }
        </dl>
    </div>
</div>

<div class="mt-2 d-flex gap-2 flex-wrap">
    @* Close: Inspector and Admin only *@
    @if (canEdit && Model.Status == FollowUpStatus.Open)
    {
        <form asp-controller="FollowUps" asp-action="Close" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button class="btn btn-success">✔ Mark as Closed</button>
        </form>
    }
    <a asp-controller="Inspections" asp-action="Details" asp-route-id="@Model.InspectionId"
       class="btn btn-outline-primary">← Back to Inspection</a>
    <a asp-controller="Premises" asp-action="Details" asp-route-id="@Model.Inspection?.PremisesId"
       class="btn btn-outline-secondary">← Back to Premises</a>
    <a asp-action="Index" class="btn btn-outline-secondary">All Follow-Ups</a>
</div>
